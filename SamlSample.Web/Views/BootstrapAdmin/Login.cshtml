@model SamlSample.Web.Models.BootstrapAdminLoginViewModel
@{
    ViewData["Title"] = "Bootstrap Admin Login";
}

<h2>Bootstrap Admin Login</h2>
<p>Use this local-only credential for first-time setup, then disable it from the admin portal.</p>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" asp-controller="BootstrapAdmin" asp-action="Login" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" autocomplete="username" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" autocomplete="current-password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2 mt-2">
        <button type="submit" class="btn btn-primary">Sign in as bootstrap admin</button>
        <a href="/saml/saml-launcher/login?returnUrl=%2FAdmin%2FSso" class="btn btn-outline-secondary">Sign in with SSO</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
