@{
    ViewData["Title"] = "SAML Login Failed";
}

<div class="alert alert-danger">
    <h4>SAML sign-in failed</h4>
    <p>The SAML response could not be validated or SSO is not configured correctly.</p>
    @if (TempData["Error"] is string error)
    {
        <p><strong>Details:</strong> @error</p>
    }
</div>

<a class="btn btn-primary" asp-controller="Home" asp-action="Index">Back to home</a>
