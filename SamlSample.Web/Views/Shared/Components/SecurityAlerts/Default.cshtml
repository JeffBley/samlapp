@model SamlSample.Web.ViewComponents.SecurityAlertsModel

@if (Model.SsoNotConfigured)
{
    <div class="alert alert-warning rounded-0 border-start-0 border-end-0 mb-0 py-2" role="alert">
        <div class="container d-flex align-items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
            </svg>
            <div>
                <strong>Security Warning:</strong> SSO is not configured for the SAML Launcher Admin Portal.
                @if (User.IsInRole("admin"))
                {
                    <a asp-area="Admin" asp-controller="Sso" asp-action="Index" class="alert-link ms-1">Configure it in the Admin Portal.</a>
                }
            </div>
        </div>
    </div>
}
else if (Model.BootstrapEnabled)
{
    <div class="alert alert-warning rounded-0 border-start-0 border-end-0 mb-0 py-2" role="alert">
        <div class="container d-flex align-items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
            </svg>
            <div>
                <strong>Security Warning:</strong> Bootstrap Admin is still enabled.
                @if (User.IsInRole("admin"))
                {
                    <span> Please disable it under <a asp-area="Admin" asp-controller="AppControls" asp-action="Index" class="alert-link">App Controls in the Admin Portal</a>.</span>
                }
            </div>
        </div>
    </div>
}
