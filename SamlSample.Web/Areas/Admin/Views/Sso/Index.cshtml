@model SamlSample.Web.Models.Admin.AdminSsoListViewModel
@{
    ViewData["Title"] = "SSO Configuration";
}

<h2>SSO Configuration</h2>
<p>Manage SAML application configurations. Each app has its own SP settings, IdP settings, and signing certificates.</p>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row">
    <div class="col-md-3 mb-3">
        <partial name="_AdminTray" />
    </div>
    <div class="col-md-9">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <form method="get" asp-area="Admin" asp-controller="Sso" asp-action="Index" class="d-flex gap-2">
                <input name="search" value="@Model.Search" class="form-control saml-search-input" placeholder="Search by name…" />
                <button type="submit" class="btn btn-outline-secondary">Search</button>
                @if (!string.IsNullOrWhiteSpace(Model.Search))
                {
                    <a asp-area="Admin" asp-controller="Sso" asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                }
            </form>
            <form asp-area="Admin" asp-controller="Sso" asp-action="RefreshAllMetadata" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary">&#8635; Refresh Federation Metadata</button>
            </form>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAppModal">
                + Add New App
            </button>
        </div>

        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>App Name</th>
                    <th>Configured</th>
                    <th>Entity ID</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Apps.Count == 0)
                {
                    <tr>
                        <td colspan="3">@(string.IsNullOrWhiteSpace(Model.Search) ? "No apps configured yet. Click \"+ Add New App\" to get started." : "No apps match your search.")</td>
                    </tr>
                }
                else
                {
                    foreach (var app in Model.Apps)
                    {
                        <tr>
                            <td>@app.AppName</td>
                            <td class="text-center">
                                @if (app.IsConfigured)
                                {
                                    <span class="text-success" title="SSO configured">&#10003;</span>
                                }
                                else
                                {
                                    <span class="text-danger" title="SSO not configured">&#10007;</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex justify-content-between align-items-center">
                                    <code class="text-muted">@(string.IsNullOrWhiteSpace(app.SpEntityId) ? "(not set)" : app.SpEntityId)</code>
                                    <div class="dropdown ms-2">
                                        <button class="btn btn-sm btn-link text-secondary p-0 lh-1 saml-ellipsis-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            &#8942;
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" asp-area="Admin" asp-controller="Sso" asp-action="Edit" asp-route-id="@app.Id">Edit</a>
                                            </li>
                                            @if (!string.IsNullOrEmpty(app.FederationMetadataUrl))
                                            {
                                                <li>
                                                    <form asp-area="Admin" asp-controller="Sso" asp-action="RefreshMetadata" asp-route-id="@app.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="dropdown-item">&#8635; Refresh Federation Metadata</button>
                                                    </form>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                            }
                                            <li>
                                                @if (app.IsSystem)
                                                {
                                                    <button type="button" class="dropdown-item text-muted" disabled title="System apps cannot be deleted">
                                                        Delete
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="dropdown-item text-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteAppModal"
                                                        data-app-id="@app.Id"
                                                        data-app-name="@app.AppName">
                                                        Delete
                                                    </button>
                                                }
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>
</div>

<!-- Add New App Modal -->
<div class="modal fade" id="addAppModal" tabindex="-1" aria-labelledby="addAppModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addAppModalLabel">Add New App</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-area="Admin" asp-controller="Sso" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <label for="appNameInput" class="form-label">App Name</label>
                    <input type="text" class="form-control" id="appNameInput" name="appName"
                           placeholder="e.g. My HR System" required autofocus maxlength="100" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete App Confirmation Modal -->
<div class="modal fade" id="deleteAppModal" tabindex="-1" aria-labelledby="deleteAppModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteAppModalLabel">Delete App</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteAppName"></strong>?</p>
                <p class="text-muted small">All associated signing certificates will also be deleted. This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteAppForm" asp-area="Admin" asp-controller="Sso" asp-action="DeleteApp" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteAppId" name="id" value="" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>



