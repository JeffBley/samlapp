@model IReadOnlyList<SamlSample.Web.Models.SignInLog>
@{
    ViewData["Title"] = "Sign-in Logs";
    var currentSort = (ViewData["Sort"] as string) ?? "desc";
    var nextSort = string.Equals(currentSort, "desc", StringComparison.OrdinalIgnoreCase) ? "asc" : "desc";
}

<h2>Sign-in Logs</h2>
<p>Records each successful SAML sign-in with the user name, timestamp, and signing certificate used.</p>

<div class="row">
    <div class="col-md-3 mb-3">
        <partial name="_AdminTray" />
    </div>
    <div class="col-md-9">

        <div class="mb-3">
            <a asp-area="Admin" asp-controller="SignInLogs" asp-action="Index" asp-route-sort="@nextSort" class="btn btn-outline-primary btn-sm">
                Sort by date: @(string.Equals(currentSort, "desc", StringComparison.OrdinalIgnoreCase) ? "Newest first" : "Oldest first")
            </a>
        </div>

        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Date (UTC)</th>
                    <th>App</th>
                    <th>User</th>
                    <th>Cert Thumbprint</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="4">No sign-in events recorded yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SignedInUtc.ToString("u")</td>
                            <td>@item.AppName</td>
                            <td>@item.UserName</td>
                            <td><code>@item.CertThumbprint</code></td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>
</div>
