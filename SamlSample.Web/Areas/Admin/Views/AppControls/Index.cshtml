@model SamlSample.Web.Models.Admin.AdminAppControlsViewModel
@{
    ViewData["Title"] = "App Controls";
}

<h2>App Controls</h2>
<p>Manage log retention for configuration change logs.</p>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row">
    <div class="col-md-3 mb-3">
        <partial name="_AdminTray" />
    </div>
    <div class="col-md-9">

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Bootstrap Login</h5>
                <p class="mb-2">After SAML SSO works, disable local bootstrap admin login to reduce attack surface.</p>
                @if (Model.BootstrapLoginEnabled)
                {
                    <form asp-area="" asp-controller="BootstrapAdmin" asp-action="Disable" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex align-items-center gap-2">
                            <div class="input-group saml-toggle-select">
                                <select class="form-select" data-auto-submit name="__status">
                                    <option value="enabled" selected>Enabled</option>
                                    <option value="disabled">Disabled</option>
                                </select>
                            </div>
                            <span class="text-danger fs-5" title="Enabled">&#10007;</span>
                        </div>
                    </form>
                }
                else
                {
                    <form asp-area="" asp-controller="BootstrapAdmin" asp-action="Enable" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex align-items-center gap-2">
                            <div class="input-group saml-toggle-select">
                                <select class="form-select" data-auto-submit name="__status">
                                    <option value="enabled">Enabled</option>
                                    <option value="disabled" selected>Disabled</option>
                                </select>
                            </div>
                            <span class="text-success fs-5" title="Disabled">&#10003;</span>
                        </div>
                    </form>
                }
            </div>
        </div>

        <form asp-area="Admin" asp-controller="AppControls" asp-action="Save" method="post" class="mb-4">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="LogRetentionDays" class="form-label"></label>
                <input asp-for="LogRetentionDays" class="form-control" min="1" max="3650" />
                <span asp-validation-for="LogRetentionDays" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save App Controls</button>
        </form>

        <form asp-area="Admin" asp-controller="AppControls" asp-action="Purge" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary">Purge Old Logs</button>
            <div class="form-text mt-1">Removes all audit and sign-in log entries older than the retention period.</div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
